# Secrets - never commit these
.env
.env.*
*.env
*.pem
*.key

# Centralized agent secrets
.env.agents

# Claude Code local settings (contains bot tokens)
.claude/settings.local.json
.claude/telegram/.env
.claude/telegram/access.json
.claude/telegram/inbox/
.claude/discord/.env
.claude/discord/access.json
.claude/discord/inbox/
.claude/discord/approved/

# Agent-specific secrets
agents/*/.claude/telegram/.env
agents/*/.claude/settings.local.json

# MCP config (may contain server entries)
.mcp.json

# Session logs
session.log
agents/*/session.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
*.swp
*.swo
*~
